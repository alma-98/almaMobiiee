rules_version = '2';

service cloud.firestore {

  match /databases/{database}/documents {

    function isAdmin() {

      return
        request.auth != null
        &&
        request.auth.token.email
        ==
        "alma.budsteddy88@gmail.com";

    }


    match /mediators/{documentId} {

      allow create:
        if
          request.resource.data.keys()
          .hasOnly([
            "publicId",
            "name",
            "phone",
            "email",
            "city",
            "reason",
            "paymentStatus",
            "status",
            "createdAt",
            "updatedAt"
          ])
          &&
          request.resource.data.status
          ==
          "pending";

      allow read,
            update,
            delete:
        if isAdmin();

    }


    match /used_cars/{documentId} {

      allow create:
        if
          request.resource.data.keys()
          .hasOnly([
            "publicId",
            "ownerName",
            "phone",
            "car",
            "year",
            "price",
            "adminFee",
            "adminFeeRate",
            "paymentStatus",
            "status",
            "createdAt",
            "updatedAt"
          ])
          &&
          request.resource.data.adminFeeRate
          ==
          0.025;

      allow read,
            update,
            delete:
        if isAdmin();

    }


    match /insurance_requests/{documentId} {

      allow create:
        if
          request.resource.data.keys()
          .hasOnly([
            "publicId",
            "name",
            "car",
            "year",
            "status",
            "createdAt",
            "updatedAt"
          ]);

      allow read,
            update,
            delete:
        if isAdmin();

    }


    match /{document=**} {

      allow read,
            write:
        if false;

    }

  }

}
